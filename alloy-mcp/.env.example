# Alloy MCP server config
ALLOY_SUPABASE_URL=https://db.forj.se   # the Alloy backend (self-hosted Supabase box)
ALLOY_ANON_KEY=                          # the PUBLIC anon JWT (ANON_KEY in the box .env / the app's anonKey). Satisfies verify_jwt; the box enforces budget caps.
ALLOY_MODEL=claude-sonnet-4-5            # must be in the proxy ALLOWED_MODELS

# Remote (HTTP) transport only, for hosting this server so Amazon Quick / other remote clients can reach it:
ALLOY_MCP_TOKEN=                         # a strong bearer token; the HTTP wrapper rejects calls without it

# DESK TOOLS ONLY (src/desk.mjs, stdio entry). Read the corpus + contacts directly over PostgREST.
# MUST be the box SERVICE_ROLE_KEY, not the anon key: RLS on companies admits only the
# authenticated role, so an anon key returns HTTP 200 with an EMPTY LIST rather than an error.
# Keep this local. It bypasses RLS and must never be set on the HTTP transport that serves tenants.
ALLOY_SERVICE_KEY=
