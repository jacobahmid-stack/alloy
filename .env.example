# ALLOY by FORJ — environment / secrets reference.
# This file lists EVERY secret the platform uses and where it is consumed.
# Do NOT commit real values. On Supabase these are set via: supabase secrets set KEY=value
# (or the dashboard: Project Settings -> Edge Functions -> Secrets).
# On AWS (Lambda) set them as encrypted env vars or pull from AWS Secrets Manager.

# --- Supabase platform (auto-injected by Supabase into every edge function) ---
# You do NOT set these manually on Supabase; they exist automatically. On AWS you DO
# need to provide equivalents (DB connection string, service key替/IAM).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>           # server-only; full DB access
SUPABASE_ANON_KEY=<publishable-anon-key>               # public; ships to the browser
SUPABASE_DB_URL=postgres://...                          # used by se-* + registry-search (direct PG)

# --- Anthropic (claude-proxy) ---
ANTHROPIC_API_KEY=sk-ant-...                            # THE cost driver. claude-proxy only.
ALLOWED_MODELS=claude-sonnet-4-5                        # optional allow-list (comma-sep)
MAX_TOKENS_CAP=2000                                     # optional hard cap per call
STRICT_TASKS=false                                      # keep false until the app is public

# --- BuiltWith (builtwith-lookup) — PAID, credit-metered ---
BUILTWITH_API_KEY=<builtwith-key>                       # omit to disable paid enrichment

# --- Function-to-function gateway (bulk-enrich, aws-discovery) ---
# Optional. Falls back to the embedded legacy anon JWT if unset. A structurally-valid
# Supabase JWT that passes the function gateway (verify_jwt). NOT a secret per se.
ALLOY_GATEWAY_JWT=<legacy-anon-jwt>

# --- AWS Partner Central MCP (pc-mcp) — NOT YET DEPLOYED (gated, see HANDOVER-AWS.md) ---
# Set these ONLY for the dedicated least-privilege IAM identity (see
# supabase/functions/pc-mcp/IAM_POLICY.json). NEVER the human SSO login. Earlier
# exposed AWS creds are BURNED — do not reuse.
PC_AWS_ACCESS_KEY_ID=<dedicated-iam-user-key>
PC_AWS_SECRET_ACCESS_KEY=<dedicated-iam-user-secret>
PC_AWS_SESSION_TOKEN=                                   # only if using temporary STS creds
